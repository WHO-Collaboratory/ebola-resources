{"version":3,"kind":"Article","sha256":"ab866bcc89089596b26ced5710d555acc5ab9e2bd117e385fef78677dae69f40","slug":"literature","location":"/docs/resources/Literature.md","dependencies":[],"frontmatter":{"title":"Literature","content_includes_title":false,"github":"https://github.com/WHO-Collaboratory/ebola-resources","numbering":{"title":{"offset":1}},"source_url":"https://github.com/WHO-Collaboratory/ebola-resources/blob/main/docs/resources/Literature.md","edit_url":"https://github.com/WHO-Collaboratory/ebola-resources/edit/main/docs/resources/Literature.md","exports":[{"format":"md","filename":"Literature.md","url":"/ebola-resources/build/Literature-3df1b5a73be0569fdba601d55f2fcd0f.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"The Collaboratory is collating literature relevant to the Bundibugyo virus disease outbreak. The list is an open accessible sheet assembled to support modelers, epidemiologists, researchers, and public health analysts working on this pathogen and is capturing publications, pre-prints, github repositories, data sets, tools and other outbreak related materials. The list is updated in near real-time as new publications appear. We recognize that some relevant work may still be missed, and we welcome contributions from the community. You can add to the list in the BDBV_Literature sheet in the Community_Submissions section or let us know at ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"wSTwMxG9FH"},{"type":"link","url":"mailto:collaboratory@who.int","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"collaboratory@who​.int","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"mKEkt9vqZk"}],"urlSource":"mailto:collaboratory@who.int","key":"RrWm2eAWP8"},{"type":"text","value":".","position"