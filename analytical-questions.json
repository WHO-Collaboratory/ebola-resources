":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"The questions were compiled with input from individuals with operational and analytical experience in country-level response. No formal consensus or agreement process was conducted beyond these individual consultations. As such, the questions are intended to help guide and coordinate analytical efforts while reflecting suggestions from the wider community.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"MKAhZLsy5M"},{"type":"link","url":"https://docs.google.com/spreadsheets/d/1iSZ6-BsTrQnOHvX60Q7eFAjCrqRLp559dFdKzsGj2Rw/edit?gid=0#gid=0","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"(Click here for access)","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"xGEGPCcOE9"}],"urlSource":"https://docs.google.com/spreadsheets/d/1iSZ6-BsTrQnOHvX60Q7eFAjCrqRLp559dFdKzsGj2Rw/edit?gid=0#gid=0","key":"ODe7VHWdFJ"}],"key":"WHUwKEo0x2"},{"type":"heading","depth":2,"position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Task","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"rddczLMNyk"}],"identifier":"task","label":"Task","html_id":"task","implicit":true,"key":"B1KfzLz1PP"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"Please review the questions and indicate where you are currently working or planning to work by adding your information in this link. This input will be compiled into an overview to help the community understand who is working on which topics and to identify potential gaps or bottlenecks. The objective is to support better coordination and enable more targeted collaboration where specific insights are needed for the response.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"HwXGrrZJOn"},{